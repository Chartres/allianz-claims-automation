{
  "name": "allianz-claims-automation",
  "version": "1.0.0",
  "description": "Config-driven automation for filing Allianz Care health-insurance claims from invoice PDFs.",
  "private": true,
  "type": "commonjs",
  "bin": {
    "allianz-onboard": "bin/onboard.js",
    "allianz-discover": "bin/discover.js",
    "allianz-launch": "bin/launch-chrome.js",
    "allianz-intake": "bin/intake.js",
    "allianz-reconcile": "bin/reconcile.js",
    "allianz-gmail-pull": "bin/gmail-pull.js",
    "allianz-policy": "bin/policy.js",
    "allianz-crawl": "bin/crawl.js",
    "allianz-report": "bin/report.js",
    "allianz-push-google": "bin/sheets-push.js"
  },
  "scripts": {
    "onboard": "node bin/onboard.js",
    "discover": "node bin/discover.js",
    "launch": "node bin/launch-chrome.js",
    "intake": "node bin/intake.js",
    "file": "node bin/intake.js --file",
    "submit": "node bin/intake.js --submit",
    "reconcile": "node bin/reconcile.js",
    "gmail-pull": "node bin/gmail-pull.js",
    "policy": "node bin/policy.js",
    "crawl": "node bin/crawl.js",
    "report": "node bin/report.js",
    "track": "node bin/policy.js && node bin/crawl.js && node bin/report.js",
    "push-google": "node bin/sheets-push.js",
    "test": "node test/selfcheck.js"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "playwright-core": "^1.60.0"
  }
}
