{
  "_readme": "Copy to config.json and fill in. config.json is gitignored. Doc paths are resolved relative to docsBaseDir unless absolute or starting with ~.",

  "docsBaseDir": "~/Documents/insurance-docs",

  "portal": {
    "url": "https://my.allianzcare.com/myhealth/1/home",
    "policyId": "0000000",
    "cdpPort": 9222,
    "chromeProfileDir": "./chrome-profile",
    "payee": "Insured member",
    "paymentMethod": "Bank Transfer",
    "currencyMatch": "^CZK",
    "bankAccountMatch": "1234",
    "countryMatch": "Czech Republic"
  },

  "gmail": {
    "todoLabelName": "_todo",
    "todoLabelId": "Label_XXXXXXXXXXXXXXXXX",
    "hotovoLabelId": "Label_YYYYYYYYYYYYYYYYY"
  },

  "defaultProvider": "Acme Dental",
  "providers": {
    "Acme Dental": ["acme"],
    "City Clinic": ["city clinic"]
  },

  "_benefitsNote": "Per-invoice benefit category (by provider) + expected co-insurance % per category (from your policy). Used to compute expected reimbursement and flag under/over/declined. Caps, deductibles and FX are not modelled.",
  "benefits": {
    "providerCategory": {
      "Acme Dental": "Dental treatment"
    },
    "categoryCoverage": {
      "Dental treatment": 100,
      "Dental surgery": 60,
      "Specialist fees": 80,
      "Medical practitioner fees": 80,
      "Vaccinations": 100,
      "Physiotherapy": 80,
      "Optical": 80
    },
    "defaultCategory": "Medical practitioner fees",
    "dentalPlanBenefitName": "Example Dental Plan",
    "tolerancePct": 5
  },

  "patients": {
    "Parent": { "portalLabel": "Parent Surname (1980)", "aliases": ["Parent Surname"] },
    "Child":  { "portalLabel": "Child Surname (2012)",  "aliases": ["Child Surname"] }
  },

  "treatmentTypes": {
    "orthodontic":   { "category": "Dental Expenses", "subtype": "Orthodontic treatment",     "reason": "Teeth misalignment",   "requiredDocs": ["dentalPlan", "xray"], "keywords": ["invisalign", "oblouk", "niti", "ortodont", "retainer"] },
    "routineDental": { "category": "Dental Expenses", "subtype": "Routine Dental Treatment",   "reason": "Dental Treatment",     "requiredDocs": [],                     "keywords": ["zubního kamene", "zubního povlaku", "hygiena", "preventivní", "prohlídka", "bitewing"] },
    "laboratory":    { "category": "Tests/Scans",     "subtype": "Laboratory tests",          "reason": "Routine Health Check", "requiredDocs": [],                     "keywords": ["laborator", "odběr krve", "lab fee", "igg", "krevní"] },
    "vaccination":   { "category": "Vaccination",     "subtype": null,                        "reason": null,                   "requiredDocs": [],                     "keywords": ["očkov", "vakcín", "vaccinat"] },
    "prescription":  { "category": "Medication and Medical Aids", "subtype": null,             "reason": null,                   "requiredDocs": ["prescription"],       "keywords": ["lék", "recept", "lékárna", "pharmacy", "medication"] },
    "doctorVisit":   { "category": "Doctor Visit",    "subtype": null,                        "reason": null,                   "requiredDocs": [],                     "keywords": ["konzultace", "vyšetření", "consultation"] }
  },

  "supplementaryDocs": {
    "dentalPlan":   { "Child": "Child/dental-plan.pdf" },
    "xray":         { "Child": ["Child/opg.png"] },
    "prescription": { "Parent": "Parent/prescription.pdf" }
  },

  "patientOverrides": {
    "Child": { "forceTreatmentType": "routineDental", "note": "Example: file ortho visits as routine when no plan is on file." }
  }
}
