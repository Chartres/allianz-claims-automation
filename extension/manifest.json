{
  "manifest_version": 3,
  "name": "Allianz Claims Helper",
  "version": "0.1.0",
  "description": "File Allianz Care claims and track reimbursements from your logged-in tab. No cloud, no Google account.",
  "permissions": ["storage", "scripting", "activeTab", "sidePanel", "offscreen", "alarms", "downloads"],
  "host_permissions": ["https://my.allianzcare.com/*"],
  "content_security_policy": { "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'" },
  "background": { "service_worker": "src/background/service-worker.js", "type": "module" },
  "side_panel": { "default_path": "src/sidepanel/panel.html" },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": {
    "default_title": "Allianz Claims Helper",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "content_scripts": [
    {
      "matches": ["https://my.allianzcare.com/*"],
      "js": ["src/content/driver.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options/options.html",
  "web_accessible_resources": [
    {
      "resources": ["src/content/formDriver.js", "src/content/dropUpload.js"],
      "matches": ["https://my.allianzcare.com/*"]
    }
  ]
}
