{
  "manifest_version": 3,
  "name": "Allianz Claims Helper",
  "version": "0.1.0",
  "description": "File Allianz Care claims and track reimbursements from your logged-in tab. No cloud, no Google account.",
  "permissions": ["storage", "scripting", "activeTab", "sidePanel", "offscreen", "alarms", "downloads"],
  "host_permissions": ["https://my.allianzcare.com/*"],
  "background": { "service_worker": "src/background/service-worker.js", "type": "module" },
  "side_panel": { "default_path": "src/sidepanel/panel.html" },
  "action": { "default_title": "Allianz Claims Helper" },
  "content_scripts": [
    {
      "matches": ["https://my.allianzcare.com/*"],
      "js": ["src/content/driver.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options/options.html"
}
